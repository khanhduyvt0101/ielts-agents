{
	"compilerOptions": {
		"moduleResolution": "bundler",
		"module": "esnext",
		"target": "es2024",
		"lib": ["es2024"],
		"allowJs": false,
		"strict": true,
		"incremental": true,
		"verbatimModuleSyntax": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"importHelpers": true,
		"noEmit": true
	}
}
